# =============================================================================
# PromptLens website — environment variables
# Copy this file to .env.local for local dev, or paste into your hosting
# dashboard (Vercel / Cloudflare Pages / Netlify) for production.
# =============================================================================

# -----------------------------------------------------------------------------
# Resend — waitlist email collection
# -----------------------------------------------------------------------------
# 1. Sign up at https://resend.com (free tier: 3k contacts, 100 emails/day)
# 2. API Keys → Create API Key → "PromptLens website" → server-side scope
# 3. Audiences → Create Audience → "PromptLens Waitlist" → copy ID

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# General audience — used for the homepage waitlist (feature='website_cta')
RESEND_AUDIENCE_ID=00000000-0000-0000-0000-000000000000

# Per-platform audiences — created separately in Resend so you can see
# macOS demand vs Windows demand at a glance. If unset, fall back to the
# general audience above.
RESEND_AUDIENCE_ID_MACOS=
RESEND_AUDIENCE_ID_WINDOWS=

# -----------------------------------------------------------------------------
# Founder notification email (optional)
# -----------------------------------------------------------------------------
# When set, every signup also fires a notification to your inbox.
# Requires the FROM domain to be verified in Resend → Domains.
# Until you verify a domain, leave these unset — adding to audience still works.

# WAITLIST_NOTIFY_FROM=hello@promptlens.cc
# WAITLIST_NOTIFY_TO=zh347487522@gmail.com

# -----------------------------------------------------------------------------
# Cloudflare Web Analytics
# -----------------------------------------------------------------------------
# 1. Cloudflare dashboard → Analytics & Logs → Web Analytics → Add a site
# 2. Choose the manual / "Add a tag" path → copy the 32-character token
#    (NOT the JS snippet — only the token inside data-cf-beacon)
# Must be NEXT_PUBLIC_ prefixed so it's exposed to the browser.

NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# -----------------------------------------------------------------------------
# Site URL (used in metadata, OG tags, sitemap)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SITE_URL=https://promptlens.cc
