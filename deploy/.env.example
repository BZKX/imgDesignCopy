# =============================================================================
# Production runtime env (server-side .env on VPS)
# Copy this file to `.env` on the server, fill in real values, and run docker
# compose. Never commit .env to git.
# =============================================================================

# ----- Image tag (override if pushing under a different repo / tag) ----------
# WEBSITE_IMAGE=ghcr.io/bzkx/promptlens-website:latest

# ----- Resend (waitlist) -----------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# General audience — homepage waitlist (feature='website_cta')
RESEND_AUDIENCE_ID=99e14236-b33d-4ac9-91f4-fcca469c387d

# Per-platform audiences — fall back to RESEND_AUDIENCE_ID if unset
RESEND_AUDIENCE_ID_MACOS=
RESEND_AUDIENCE_ID_WINDOWS=

# Optional notification email (leave commented until you verify a domain in Resend)
# WAITLIST_NOTIFY_FROM=hello@promptlens.cc
# WAITLIST_NOTIFY_TO=zh347487522@gmail.com

# ----- Public env (already baked into the image at build time) ---------------
# These are also exported at runtime so server-side route handlers can read them.
NEXT_PUBLIC_SITE_URL=https://promptlens.cc

# Leave blank — Cloudflare proxy + Auto Web Analytics tracks everything at the
# edge without a script tag. Only set this if you switch CF proxy off and want
# manual beacon injection instead.
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN=
