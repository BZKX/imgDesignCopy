node_modules
dist
.claude/scheduled_tasks.lock
*.log
.env
.env.local
.DS_Store
playwright-report
test-results
coverage

# OMC / agent runtime state — never commit (contains conversation traces)
**/.omc/
!**/.omc/plans/         # keep human-readable plans
!**/.omc/notepad.md     # keep notepads
**/.omc/state/
**/.omc/sessions/
**/.omc/logs/

# Editor / IDE configs — personal, not part of the project
.vscode/
.idea/

# TypeScript incremental build caches
*.tsbuildinfo

# Next.js build artifacts (should not have been committed in v0.2.0)
apps/website/.next/

# Production deploy secrets — only ever live on the VPS
deploy/.env
deploy/cert/*
!deploy/cert/.gitkeep
