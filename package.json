{
  "name": "promptlens-monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "PromptLens — Chrome + Tauri monorepo. Turns on-page/desktop image selections into prompts and design insights.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev:chrome": "pnpm --filter @promptlens/chrome dev",
    "dev:desktop": "pnpm --filter @promptlens/desktop dev",
    "build:chrome": "bash scripts/pack-chrome.sh",
    "build:desktop": "bash scripts/pack-desktop.sh",
    "build:all": "pnpm build:chrome && pnpm build:desktop",
    "test:chrome": "pnpm --filter @promptlens/chrome test",
    "test:core": "pnpm --filter @promptlens/core test",
    "dev:website": "pnpm --filter @promptlens/website dev",
    "build:website": "pnpm --filter @promptlens/website build"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3"
  }
}
